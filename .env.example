# 필요한 환경변수 이름을 보여주는 샘플 파일

# 공공데이터포털 서비스키 — 한국 종목 검증/주가 조회
# 발급: https://www.data.go.kr
DATA_GO_KR_SERVICE_KEY=

# Finnhub API 키 — 미국 종목 검증/주가 조회
# 발급: https://finnhub.io (무료 가입)
FINNHUB_API_KEY=

# FMP API 키 — 미국 종목 일봉 히스토리/기술적 지표
# 발급: https://site.financialmodelingprep.com (무료 가입, 250회/일)
FMP_API_KEY=

# 선택: 종목 마스터 캐시 위치를 바꿔 테스트할 때만 사용
STOCK_SYMBOL_CACHE_DIR=
